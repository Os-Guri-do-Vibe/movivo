# Normaliza fim de linha para LF no repositório (o time usa Windows, Linux e CI Ubuntu).
* text=auto eol=lf

pnpm-lock.yaml linguist-generated=true -diff

# Scripts de shell precisam de LF mesmo em checkout Windows (Git Bash / CI Ubuntu).
*.sh text eol=lf
*.ps1 text eol=lf

*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.svg text eol=lf
