# =============================================================================
# MOVIVO — .env.example (RAIZ do monorepo)
# =============================================================================
# Dono: Henrique (Platform/SRE) · US-0.6 · Sprint 0
#
# COMO USAR
#   1. cp .env.example .env
#   2. Ajuste apenas o que for específico da sua máquina.
#   3. NUNCA coloque um valor real de senha/chave aqui. Este arquivo é versionado.
#
# ONDE FICAM AS SENHAS
#   Em NENHUM lugar deste arquivo. Todo valor sensível vive em Docker Secrets,
#   gerados localmente por `scripts/gen-local-secrets.sh` (ou `.ps1`) dentro de
#   `secrets/` (ignorado pelo Git) e montados em `/run/secrets/*` pelos
#   containers. A aplicação lê o valor pelo par `<VAR>_FILE` — ver SECURITY.md
#   §"Contrato de consumo de secrets (*_FILE)".
#
# REGRAS INEGOCIÁVEIS QUE ESTE ARQUIVO MATERIALIZA
#   · ARQUITETURA.md §12.7  — nunca versionar segredos.
#   · ARQUITETURA.md §12.3  — a aplicação conecta no Postgres SEMPRE na 5433
#                             (PgBouncer). Nunca na 5432.
#   · Sato §9.3             — segredos em /run/secrets (somente leitura, fora da
#                             imagem), nunca em `environment:` do Compose.
# =============================================================================


# -----------------------------------------------------------------------------
# 1. AMBIENTE / RUNTIME
# -----------------------------------------------------------------------------
NODE_ENV=development
# Fuso horário canônico do produto (check-in semanal seg 08–10h BRT — ARQUITETURA §8)
TZ=America/Sao_Paulo
# Rótulo livre de ambiente para logs/telemetria: local | ci | staging | production
APP_ENV=local


# -----------------------------------------------------------------------------
# 2. DOCKER COMPOSE — nomes, portas de host e imagens (consumido por US-0.2)
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=movivo

# Imagens fixadas. Redis: versão MÍNIMA obrigatória com patch da CVE-2025-49844
# (RediShell) — ARQUITETURA.md §12.14. Nunca rebaixar.
POSTGRES_IMAGE=pgvector/pgvector:pg17
PGBOUNCER_IMAGE=edoburu/pgbouncer:v1.24.1-p1
REDIS_IMAGE=redis:8.2.2-alpine

# Portas publicadas no HOST apenas para conveniência de dev (psql/redis-cli).
# Em produção nada disso é publicado — bind só na rede interna `movivo-net`.
# A 5432 do Postgres NÃO é publicada: a app fala com o PgBouncer (5433).
HOST_PGBOUNCER_PORT=5433
HOST_REDIS_PORT=6379
HOST_SENTINEL_PORT=26379


# -----------------------------------------------------------------------------
# 3. POSTGRESQL + PGBOUNCER
# -----------------------------------------------------------------------------
# A aplicação usa a role `movivo_app`, que NUNCA tem BYPASSRLS e NUNCA é dona
# das tabelas (Sato §4.3 / ARQUITETURA.md §8).
POSTGRES_DB=movivo
POSTGRES_APP_USER=movivo_app
POSTGRES_MIGRATOR_USER=movivo_migrator
POSTGRES_SUPERUSER=postgres

# --- Conexão de RUNTIME da aplicação: SEMPRE via PgBouncer, porta 5433 ---
DATABASE_HOST=pgbouncer
DATABASE_PORT=5433
DATABASE_NAME=movivo
DATABASE_USER=movivo_app
DATABASE_SSL=false
# Senha: lida do Docker Secret. NUNCA defina DATABASE_PASSWORD em .env real.
DATABASE_PASSWORD_FILE=/run/secrets/postgres_app_password
# PgBouncer roda em transaction mode → prepared statements PROIBIDOS (ADR-003).
# Flag explícita para o DatabaseModule (US-0.3) desligar o prepare do driver.
DATABASE_PREPARE=false
DATABASE_POOL_MAX=10

# --- Conexão de MIGRAÇÃO (drizzle-kit): direto no Postgres, porta 5432 ---
# Exceção justificada e única à regra da 5433: DDL e advisory locks de migração
# não sobrevivem a transaction pooling. Quem migra é `movivo_migrator`, que NÃO
# é a aplicação. O runtime da API nunca abre conexão na 5432.
MIGRATION_DATABASE_HOST=postgres
MIGRATION_DATABASE_PORT=5432
MIGRATION_DATABASE_USER=movivo_migrator
MIGRATION_DATABASE_PASSWORD_FILE=/run/secrets/postgres_migrator_password


# -----------------------------------------------------------------------------
# 4. REDIS + SENTINEL
# -----------------------------------------------------------------------------
# A app descobre o master pelo Sentinel (ADR-004: master + replica + 3 sentinels,
# quorum=2). Em dev sobe 1 sentinel; o contrato de env é o mesmo.
REDIS_SENTINEL_HOSTS=redis-sentinel:26379
REDIS_SENTINEL_MASTER_NAME=movivo-master
REDIS_DB=0
REDIS_TLS_ENABLED=false
# Prefixo de tenant isolation — toda chave é prefixada por user_id (Sato §4.3).
REDIS_KEY_PREFIX=movivo
# Senhas: Docker Secrets. NUNCA REDIS_PASSWORD em claro.
REDIS_PASSWORD_FILE=/run/secrets/redis_password
REDIS_SENTINEL_PASSWORD_FILE=/run/secrets/redis_password


# -----------------------------------------------------------------------------
# 5. API (NestJS — US-0.3)
# -----------------------------------------------------------------------------
API_PORT=3001
API_GLOBAL_PREFIX=api/v1
# Origens permitidas (CSV). Nunca `*` fora de local.
API_CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=debug
# Redaction obrigatória: telefone/PII nunca em log claro (LGPD Art. 11 · Sato §9).
LOG_REDACT_PII=true


# -----------------------------------------------------------------------------
# 6. WEB (Next.js 15 — US-0.5)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_* é EXPOSTO AO BROWSER. Só valor público entra aqui — jamais secret.
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
# PostHog: a project API key é pública por desenho (ingestão). A Personal API Key
# (privada) NÃO entra aqui e nem no cliente.
NEXT_PUBLIC_POSTHOG_KEY=phc_placeholder_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com


# =============================================================================
# 7. RESERVADO PARA AS PRÓXIMAS SPRINTS — mantido COMENTADO de propósito
# -----------------------------------------------------------------------------
# Não descomente sem que o secret correspondente exista. O ConfigModule (US-0.3)
# valida por Zod e falha rápido no boot se a variável existir mas o arquivo não.
# Cadência de rotação de cada item: SECURITY.md §"Inventário e rotação".
# =============================================================================

# --- AUTH / JWT (Sprint 2) — RS256 obrigatório, nunca HS256 (Sato §9.1) -------
# JWT_ALGORITHM=RS256
# JWT_KEY_ID=movivo-2026-q3
# JWT_PRIVATE_KEY_FILE=/run/secrets/jwt_private_key
# JWT_PUBLIC_KEY_FILE=/run/secrets/jwt_public_key
# JWT_ACCESS_TTL=15m
# JWT_REFRESH_TTL=30d
# AUTH_SECRET_FILE=/run/secrets/authjs_secret        # Auth.js v5 (dashboard CREF)

# --- Criptografia de dados de saúde (Sprint 2) — LGPD Art. 11 ----------------
# PGCRYPTO_KEY_FILE=/run/secrets/pgcrypto_key

# --- WhatsApp / AraraHQ (Sprint 3) ------------------------------------------
# ARARAHQ_BASE_URL=https://api.ararahq.com
# ARARAHQ_API_KEY_FILE=/run/secrets/ararahq_api_key
# ARARAHQ_WEBHOOK_SECRET_FILE=/run/secrets/ararahq_webhook_secret
# ARARAHQ_WEBHOOK_TOLERANCE_SECONDS=300   # janela ±5min anti-replay (§12.15)

# --- Pagamentos (Sprint 5) --------------------------------------------------
# STRIPE_SECRET_KEY_FILE=/run/secrets/stripe_secret_key
# STRIPE_WEBHOOK_SECRET_FILE=/run/secrets/stripe_webhook_secret
# ASAAS_API_KEY_FILE=/run/secrets/asaas_api_key
# ASAAS_WEBHOOK_SECRET_FILE=/run/secrets/asaas_webhook_secret

# --- LLM (Sprint 4) — GPT-4.1 principal / Claude Sonnet 4.5 fallback --------
# NUNCA DeepSeek, em nenhum fluxo (ADR-005-R / regra §12.11).
# OPENAI_API_KEY_FILE=/run/secrets/openai_api_key
# ANTHROPIC_API_KEY_FILE=/run/secrets/anthropic_api_key
# LLM_PRIMARY_MODEL=gpt-4.1
# LLM_FALLBACK_MODEL=claude-sonnet-4-5
# LLM_EMBEDDING_MODEL=text-embedding-3-small
# LLM_MAX_TOKENS=500                       # teto de custo por resposta (Sato §9.4)
# LLM_CIRCUIT_BREAKER_MS=2000
# LLM_USER_DAILY_MESSAGE_LIMIT=50          # anti-abuso LLM10 (Sato §9.4)

# --- Observabilidade (Sprint 6) ---------------------------------------------
# SENTRY_DSN=
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# OTEL_SERVICE_NAME=movivo-api
