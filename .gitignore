.DS_Store
.claude/settings.local.json

# Dependências
node_modules/
.pnpm-store/

# Build / cache
dist/
build/
out/
.next/
.turbo/
.cache/
*.tsbuildinfo
.eslintcache

# Gerado pelo `next dev`/`next build` a cada execução. Versioná-lo só produziria
# diff de ruído — o Next o recria e o sobrescreve sem pedir licença.
next-env.d.ts

# ─────────────────────────────────────────────────────────────────────────────
# Ambiente e segredos — nunca versionar
# Regra inegociável ARQUITETURA.md §12.7 · Sato 11-relatorio-sato.md §9.3
# Dono desta seção: Henrique (US-0.6). Não afrouxar sem revisão de segurança.
# ─────────────────────────────────────────────────────────────────────────────

# Qualquer arquivo de ambiente, em qualquer diretório. Só *.example entra no Git.
.env
.env.*
*.env
!.env.example
!*.env.example
!.env.*.example

# Docker Secrets locais (gerados por scripts/gen-local-secrets.*) — NUNCA versionar.
# Padrão `dir/*` + exceções: o Git não reinclui arquivos dentro de um diretório excluído.
secrets/*
!secrets/README.md
!secrets/.gitkeep

# Material criptográfico: chaves privadas, certificados, keystores.
*.key
*.pem
*.crt
*.cer
*.der
*.p12
*.pfx
*.jks
*.keystore
*.asc
*.gpg
certs/
certificates/

# Arquivo de autenticação do PgBouncer (usuário + senha em claro)
userlist.txt

# Credenciais de cloud / CI que jamais devem entrar no repo
.npmrc.local
*.kubeconfig
kubeconfig
gha-creds-*.json

# Testes / cobertura
coverage/

# Playwright — artefatos gerados a cada execução (US-0.8, Mariana)
playwright-report/
test-results/
blob-report/
.playwright/
/apps/web/playwright/.cache/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Editor / SO
.vscode/*
!.vscode/extensions.json
Thumbs.db
