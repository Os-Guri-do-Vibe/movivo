{
  "name": "@movivo/web",
  "version": "0.1.0",
  "private": true,
  "description": "Frontend MOVIVO — Next.js 15 (App Router, React 19, Tailwind v4 + shadcn/ui com os tokens do design system \"O Pulso\").",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start --port 3000",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e": "playwright test",
    "clean": "node -e \"const{rmSync}=require('node:fs');for(const p of ['.next','dist','tsconfig.tsbuildinfo','next-env.d.ts'])rmSync(p,{recursive:true,force:true})\""
  },
  "dependencies": {
    "@movivo/shared": "workspace:*",
    "@radix-ui/react-slot": "1.3.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.25.0",
    "next": "15.5.21",
    "next-themes": "0.4.6",
    "posthog-js": "1.407.0",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "4.3.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "@vitest/coverage-istanbul": "4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "jsdom": "^29.1.1",
    "tailwindcss": "4.3.3",
    "tw-animate-css": "1.4.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
