# =============================================================================
# MOVIVO — apps/api/.env.example (backend NestJS)
# =============================================================================
# Dono: Henrique (US-0.6) · Consumido pelo ConfigModule de Leonardo (US-0.3)
#
#   cp apps/api/.env.example apps/api/.env
#
# ESTE arquivo é o perfil de quem roda a API **no host** (`pnpm --filter
# @movivo/api run dev`) enquanto o Docker Compose (US-0.2) sobe apenas os
# serviços de dados. Por isso os hosts são `localhost` e os `*_FILE` apontam
# para o diretório `secrets/` do repositório, e não para `/run/secrets/`.
#
# Quando a API roda DENTRO do Compose, os mesmos nomes de variável são usados,
# mas com os valores do `.env.example` da raiz (host = nome do serviço,
# `*_FILE` = /run/secrets/...). O código não muda — só o caminho.
#
# Precedência de leitura, contrato completo em SECURITY.md:
#   <VAR>_FILE (arquivo)  >  <VAR> (env direta)  >  falha rápida no boot.
# Nenhum valor sensível pode ser escrito neste arquivo — ele é versionado.
# =============================================================================

NODE_ENV=development
APP_ENV=local
TZ=America/Sao_Paulo

# -----------------------------------------------------------------------------
# HTTP
# -----------------------------------------------------------------------------
API_PORT=3001
API_GLOBAL_PREFIX=api/v1
API_CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=debug
LOG_REDACT_PII=true

# -----------------------------------------------------------------------------
# POSTGRES — runtime SEMPRE via PgBouncer na 5433 (ARQUITETURA.md §12.3)
# -----------------------------------------------------------------------------
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_NAME=movivo
DATABASE_USER=movivo_app
DATABASE_SSL=false
DATABASE_PREPARE=false          # transaction pooling proíbe prepared statements
DATABASE_POOL_MAX=10
# Caminho relativo ao cwd do processo. Rodando via script do workspace, o cwd é
# apps/api → dois níveis acima está a raiz do repo.
DATABASE_PASSWORD_FILE=../../secrets/postgres_app_password

# -----------------------------------------------------------------------------
# POSTGRES — migrações (drizzle-kit, role movivo_migrator, porta 5432 direta)
# -----------------------------------------------------------------------------
MIGRATION_DATABASE_HOST=localhost
MIGRATION_DATABASE_PORT=5432
MIGRATION_DATABASE_USER=movivo_migrator
MIGRATION_DATABASE_PASSWORD_FILE=../../secrets/postgres_migrator_password

# -----------------------------------------------------------------------------
# REDIS — descoberta de master via Sentinel
# -----------------------------------------------------------------------------
REDIS_SENTINEL_HOSTS=localhost:26379
REDIS_SENTINEL_MASTER_NAME=movivo-master
REDIS_DB=0
REDIS_TLS_ENABLED=false
REDIS_KEY_PREFIX=movivo
REDIS_PASSWORD_FILE=../../secrets/redis_password
REDIS_SENTINEL_PASSWORD_FILE=../../secrets/redis_password

# =============================================================================
# RESERVADO — próximas sprints (ver .env.example da raiz para a lista completa
# e SECURITY.md para a cadência de rotação de cada secret).
# =============================================================================
# JWT_ALGORITHM=RS256
# JWT_KEY_ID=movivo-2026-q3
# JWT_PRIVATE_KEY_FILE=../../secrets/jwt_private_key
# JWT_PUBLIC_KEY_FILE=../../secrets/jwt_public_key
# PGCRYPTO_KEY_FILE=../../secrets/pgcrypto_key
# ARARAHQ_API_KEY_FILE=../../secrets/ararahq_api_key
# ARARAHQ_WEBHOOK_SECRET_FILE=../../secrets/ararahq_webhook_secret
# STRIPE_SECRET_KEY_FILE=../../secrets/stripe_secret_key
# STRIPE_WEBHOOK_SECRET_FILE=../../secrets/stripe_webhook_secret
# ASAAS_API_KEY_FILE=../../secrets/asaas_api_key
# ASAAS_WEBHOOK_SECRET_FILE=../../secrets/asaas_webhook_secret
# OPENAI_API_KEY_FILE=../../secrets/openai_api_key
# ANTHROPIC_API_KEY_FILE=../../secrets/anthropic_api_key
# SENTRY_DSN=
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=movivo-api

# -----------------------------------------------------------------------------
# REDIS — natMap (opcional, só quando a API roda no host)
# -----------------------------------------------------------------------------
# O Sentinel anuncia o master pelo hostname do Compose (`redis-master:6379`), que
# não resolve fora da rede `movivo-net`. O RedisModule (US-0.3) aplica sozinho o
# mapa abaixo quando TODOS os Sentinels configurados estão em loopback, então em
# dev normalmente não é preciso definir nada. Defina apenas se as portas
# publicadas no host forem diferentes das padrão (HOST_REDIS_PORT / _REPLICA_).
# REDIS_NAT_MAP={"redis-master:6379":{"host":"127.0.0.1","port":6379},"redis-replica:6379":{"host":"127.0.0.1","port":6380}}
