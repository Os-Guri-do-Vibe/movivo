{
  "name": "@movivo/api",
  "version": "0.1.0",
  "private": true,
  "description": "Backend MOVIVO — monólito modular NestJS (CORE + esqueleto de domínio do C4 nível 3).",
  "license": "UNLICENSED",
  "main": "dist/main.js",
  "scripts": {
    "dev": "nest start --watch",
    "start": "node --enable-source-maps dist/main.js",
    "build": "nest build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true});require('node:fs').rmSync('tsconfig.tsbuildinfo',{force:true})\""
  },
  "dependencies": {
    "@movivo/shared": "workspace:*",
    "@nestjs/common": "11.1.28",
    "@nestjs/core": "11.1.28",
    "@nestjs/platform-express": "11.1.28",
    "@nestjs/terminus": "11.1.1",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.2",
    "dotenv": "17.4.2",
    "drizzle-orm": "0.45.2",
    "ioredis": "5.11.1",
    "nestjs-pino": "4.6.1",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "postgres": "3.4.9",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.24",
    "@nestjs/schematics": "11.0.9",
    "@nestjs/testing": "11.1.28",
    "@types/node": "22.20.1",
    "@types/supertest": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "pino-pretty": "13.1.3",
    "supertest": "7.1.4",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
